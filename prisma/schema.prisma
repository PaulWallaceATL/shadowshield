generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String        @id @default(cuid())
  name               String?
  email              String        @unique
  emailVerified      DateTime?
  password           String?
  department         String?
  image              String?
  role               Role          @default(USER)
  isActive           Boolean       @default(true)
  mustChangePassword Boolean       @default(false)
  verifyToken        String?       @unique
  resetToken         String?       @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  accounts           Account[]
  resolvedAlerts     Alert[]       @relation("AlertResolver")
  alerts             Alert[]
  chats              Chat[]
  queries            Query[]
  sessions           Session[]
  requestedRequests  UserRequest[] @relation("RequestedBy")
  reviewedRequests   UserRequest[] @relation("ReviewedBy")
  settings           UserSettings?
  apiKeys            APIKey[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  userAgent    String?
  ipAddress    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Query {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  model     String
  response  String?
  latency   Int?
  tokens    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  Json?
  content   String
  chatId    String
  status    String   @default("PENDING")
  alerts    Alert[]
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chatId])
}

model DLPRule {
  id          String    @id @default(uuid())
  name        String
  pattern     String
  description String?
  type        DLPType
  severity    Severity
  action      DLPAction
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Alert {
  id           String    @id @default(uuid())
  message      String
  metadata     Json?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  chatId       String?
  notes        String?
  queryId      String?
  resolvedBy   String?
  userId       String
  updatedAt    DateTime  @updatedAt
  type         String
  severity     String
  status       String    @default("PENDING")
  chat         Chat?     @relation(fields: [chatId], references: [id])
  query        Query?    @relation(fields: [queryId], references: [id])
  resolvedUser User?     @relation("AlertResolver", fields: [resolvedBy], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chatId])
  @@index([queryId])
}

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  settings  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model UserRequest {
  id            String   @id @default(uuid())
  email         String
  name          String?
  role          Role     @default(USER)
  department    String?
  status        String   @default("PENDING")
  notes         String?
  requestedById String
  reviewedById  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  requestedBy   User     @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedBy    User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])
}

model APIKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@map("api_keys")
}

model Chat {
  id          String   @id @default(cuid())
  title       String
  userId      String
  provider    String?
  model       String?
  messages    Json[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isAdminTest Boolean  @default(false)
  alerts      Alert[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  queries     Query[]

  @@index([userId])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum QueryStatus {
  PENDING
  PROCESSED
  FAILED
  FLAGGED
}

enum LLMProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  DLP_VIOLATION
  SYSTEM_ERROR
  AUTHENTICATION_FAILURE
  API_ERROR
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  ESCALATED
}

enum DLPType {
  REGEX
  KEYWORD
  ENTITY
}

enum DLPAction {
  ALERT
  BLOCK
  REDACT
}
