DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-32-byte-random-secret"

# App encryption (used for encrypting stored provider keys/settings)
ENCRYPTION_KEY="replace-with-64-char-random-hex-or-long-passphrase"

# LLM providers
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""

# Optional (only needed if you wire real transactional email)
# SENDGRID_API_KEY=""

# Seed users (used by `npm run prisma:seed`)
SEED_SUPERADMIN_EMAIL="admin@example.com"
SEED_SUPERADMIN_NAME="Platform Super Admin"
SEED_SUPERADMIN_PASSWORD=""
SEED_SUPERADMIN_DEPARTMENT="Security"

# Optional second admin account
SEED_ADMIN_EMAIL="org-admin@example.com"
SEED_ADMIN_NAME="Organization Admin"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_DEPARTMENT="Operations"
