# Supabase: use EITHER direct OR pooler for DATABASE_URL (see SUPABASE_SETUP.md).
# For Vercel, try direct first; if you see "can't reach", use Transaction pooler URI from dashboard.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
# Required for Prisma migrations; use same direct connection.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-32-byte-random-secret"

# App encryption (used for encrypting stored provider keys/settings)
ENCRYPTION_KEY="replace-with-64-char-random-hex-or-long-passphrase"

# LLM providers
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""

# Optional (only needed if you wire real transactional email)
# SENDGRID_API_KEY=""

# Seed users (used by `npm run prisma:seed`)
SEED_SUPERADMIN_EMAIL="admin@example.com"
SEED_SUPERADMIN_NAME="Platform Super Admin"
SEED_SUPERADMIN_PASSWORD=""
SEED_SUPERADMIN_DEPARTMENT="Security"

# Optional second admin account
SEED_ADMIN_EMAIL="org-admin@example.com"
SEED_ADMIN_NAME="Organization Admin"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_DEPARTMENT="Operations"
