DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shadowai"
NEXTAUTH_SECRET="replace-with-32-byte-random-secret"
NEXTAUTH_URL="http://localhost:3000"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
ENCRYPTION_KEY="replace-with-64-char-random-hex-or-long-passphrase"
